<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Login - Sistema Hispano</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body class="login-body">

    <div class="login-card">
        <h1>Sistema de Pasantías</h1>
        <h2>Unidad Educativa Hispano América</h2>

        <form action="/login" method="POST">
            <label>Usuario</label>
            <input type="text" name="usuario" placeholder="Ingrese su usuario" required>

            <label>Contraseña</label>
            <input type="password" name="contraseña" placeholder="Ingrese su contraseña" required>

            <button type="submit">Ingresar</button>

            <a href="/registro-usuario" class="link-registro">Registrar usuario</a>
        </form>
    </div>

</body>
</html>